includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src/
        - config/

    scanFiles:
        - stubs/phpstan/VimeoFacade.php

    level: 8
    tmpDir: build/phpstan
    checkModelProperties: false
    reportUnmatchedIgnoredErrors: false

    ignoreErrors:
        - identifier: larastan.noEnvCallsOutsideOfConfig
          path: config/*
